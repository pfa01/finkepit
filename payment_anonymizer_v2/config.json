{
  "paths": {
    "input_path":  "input/",
    "output_path": "output/",
    "log_path":    "logs/"
  },

  "file_handling": {
    "prefix":          "",
    "suffix":          "_anon",
    "file_extensions": [".xml", ".txt", ".fin"]
  },

  "anonymization": {
    "anonymize_name":          true,
    "anonymize_iban":          true,
    "anonymize_bic":           true,
    "anonymize_address_field": true,
    "anonymize_remittance":    true,
    "anonymize_contact":       true
  },

  "behavior": {
    "overwrite_existing": false
  },

  "logging": {
    "level":  "INFO",
    "format": "csv"
  },

  "message_types": {
    "iso20022": { "validate_after": false },
    "swift_mt": { "validate_after": false }
  },

